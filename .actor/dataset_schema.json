{
    "$schema": "https://apify.com/schemas/v1/dataset.ide.json",
    "actorSpecification": 1,
    "fields": {},
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": ["title", "brand", "category", "sku", "price", "rating", "ratingCount", "availability", "url"]
            },
            "display": {
                "component": "table",
                "properties": {
                    "title": {
                        "label": "Product Name",
                        "format": "text"
                    },
                    "brand": {
                        "label": "Brand",
                        "format": "text"
                    },
                    "category": {
                        "label": "Category",
                        "format": "text"
                    },
                    "sku": {
                        "label": "SKU",
                        "format": "text"
                    },
                    "price": {
                        "label": "Price (CZK)",
                        "format": "number"
                    },
                    "rating": {
                        "label": "Rating",
                        "format": "number"
                    },
                    "ratingCount": {
                        "label": "Reviews",
                        "format": "number"
                    },
                    "availability": {
                        "label": "Availability",
                        "format": "text"
                    },
                    "url": {
                        "label": "URL",
                        "format": "link"
                    }
                }
            }
        }
    }
}
